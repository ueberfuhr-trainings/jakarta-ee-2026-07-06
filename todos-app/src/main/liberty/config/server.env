# Umgebungsvariablen fuer Open Liberty (wird vom liberty-maven-plugin in das
# Server-Konfigurationsverzeichnis kopiert).
#
# Demonstriert die Config-Rangfolge von MicroProfile Config: Umgebungsvariablen
# (Ordinal 300) haben Vorrang vor META-INF/microprofile-config.properties
# (Ordinal 100). Dieser Wert ueberschreibt also das dortige
# todos.sampledata.enabled=true und deaktiviert das Anlegen der Beispieldaten.
#
# MicroProfile Config bildet den Property-Namen todos.sampledata.enabled auf
# den Variablennamen TODOS_SAMPLEDATA_ENABLED ab (Punkte -> Unterstriche,
# Grossschreibung).
TODOS_SAMPLEDATA_ENABLED=false
